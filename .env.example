# Copy to .env and fill in real values.

# Neon pooled connection string (Settings → Connection details → Pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/atlas?sslmode=require"

# Optional: Neon direct (unpooled) URL — only needed if you run prisma migrate.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/atlas?sslmode=require"

# Comma-separated list of allowed origins (or "*").
CORS_ORIGIN="http://localhost:5173,https://your-admin.replit.app"

PORT=3000
