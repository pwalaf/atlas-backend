// Prisma schema for Atlas Backend (Neon-compatible PostgreSQL)
// Mirrors the Drizzle schema used by the api-server.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  // Neon recommends a separate direct (unpooled) URL for migrations.
  // Render injects DATABASE_URL automatically when you wire a Neon database.
  // Add DIRECT_URL in your env if you want migrate/diff to use the unpooled host.
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  subject    String
  level      String
  contact    String?
  hourlyRate Decimal  @map("hourly_rate") @db.Decimal(12, 2)
  currency   String   @default("EUR")
  status     String   @default("active")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("students")
}

model LessonSession {
  id              Int      @id @default(autoincrement())
  studentId       Int      @map("student_id")
  studentName     String   @map("student_name")
  occurredAt      DateTime @map("occurred_at") @db.Timestamptz(6)
  durationMinutes Int      @map("duration_minutes")
  ratePerHour     Decimal  @map("rate_per_hour") @db.Decimal(12, 2)
  currency        String   @default("EUR")
  amount          Decimal  @db.Decimal(12, 2)
  paid            Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("lesson_sessions")
}

model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  source      String
  category    String
  amount      Decimal  @db.Decimal(14, 2)
  currency    String   @default("EUR")
  occurredAt  DateTime @map("occurred_at") @db.Timestamptz(6)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("transactions")
}

model Goals {
  id            Int      @id @default(1)
  baseCurrency  String   @default("EUR") @map("base_currency")
  monthlyTarget Decimal  @default(1000000) @map("monthly_target") @db.Decimal(16, 2)
  reinvestPct   Int      @default(40) @map("reinvest_pct")
  expensePct    Int      @default(30) @map("expense_pct")
  savingsPct    Int      @default(30) @map("savings_pct")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("goals")
}

model FxRate {
  currency   String   @id
  rateToBase Decimal  @map("rate_to_base") @db.Decimal(18, 8)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("fx_rates")
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  status    String   @default("active")
  price     Decimal  @db.Decimal(12, 2)
  currency  String   @default("EUR")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("products")
}
